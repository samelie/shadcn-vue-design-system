{
  "name": "@adddog/shadcn-vue-design-system",
  "version": "0.1.0",
  "description": "A collection of reusable Vue 3 components built with Reka UI and Tailwind CSS, following the shadcn/ui pattern",
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "design-system",
    "shadcn",
    "reka-ui",
    "tailwindcss",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./other/*": "./src/other/*",
    "./components/*": "./src/components/*",
    "./composables/*": "./src/composables/*",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/*": "./src/lib/*",
    "./styles.css": "./src/style/styles.css",
    "./houdini/*": "./src/composables/houdini/*",
    "./postcss.config": "@adddog/tailwind-theme/postcss.config",
    "./eslint-plugin": {
      "types": "./dist/eslint/index.d.mts",
      "import": "./dist/eslint/index.mjs",
      "require": "./dist/eslint/index.cjs"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "example": "cd example-app && vite",
    "prepare": "unbuild",
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "release": "bumpp --yes --no-push --no-tag --release patch",
    "prepack": "pnpm run prepublishOnly",
    "types": "vue-tsc --noEmit",
    "test": "vitest --watch=false",
    "knip": "knip",
    "version:patch": "npm version patch --no-git-tag-version",
    "dev": "tsx src/index.ts"
  },
  "author": "Sam Elie <sam@add.dog>",
  "homepage": "https://github.com/samelie/shadcn-vue-design-system#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/samelie/shadcn-vue-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/samelie/shadcn-vue-design-system/issues"
  },
  "peerDependencies": {
    "@adddog/design-tokens": "*",
    "@internationalized/date": "^3.10.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "reka-ui": "^2.9.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.22"
  },
  "peerDependenciesMeta": {
    "@adddog/design-tokens": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adddog/design-tokens": "workspace:*",
    "@adddog/monorepo-consistency": "workspace:*",
    "@internationalized/date": "^3.12.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-table": "^8.21.3",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript-eslint/rule-tester": "^8.59.0",
    "@typescript-eslint/utils": "^8.59.0",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vueuse/core": "^14.2.1",
    "bumpp": "^11.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "knip": "^6.7.0",
    "lucide-vue-next": "^0.577.0",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "unbuild": "^3.6.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.3"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 10",
    "npm": ">= 11"
  },
  "dependencies": {
    "@adddog/tailwind-theme": "workspace:*",
    "embla-carousel-vue": "^8.6.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue-input-otp": "^0.3.2",
    "vue-sonner": "^2.0.9"
  }
}
